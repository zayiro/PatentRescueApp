{
  "expo": {
    "name": "TRUE DOCTOR",
    "slug": "PatentRescueApp",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "patentrescueapp",
    "associatedDomains": [
      "applinks:truedoctor.com"
    ],
    "cache": {
      "development": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.patentrescueapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.patentrescueapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/splash-icon.png"
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "expo-sharing"
    ]
  }
}
